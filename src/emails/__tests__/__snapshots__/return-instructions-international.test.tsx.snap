exports[`ReturnInstructionsInternational > renders address and customs declaration text 1`] = `"<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd"><html dir="ltr" lang="en"><head><link rel="preload" as="image" href="https://staging.ynotlondon.com/brand/ynot-logo-black.png"/><meta content="text/html; charset=UTF-8" http-equiv="Content-Type"/><meta name="x-apple-disable-message-reformatting"/></head><body style="background-color:#ffffff;margin:0;padding:0"><!--$--><!--html--><!--head--><div style="display:none;overflow:hidden;line-height:1px;opacity:0;max-height:0;max-width:0" data-skip-in-text="true">Return RT-2026-00010 — instructions<div> ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿</div></div><!--body--><table border="0" width="100%" cellPadding="0" cellSpacing="0" role="presentation" align="center"><tbody><tr><td style="background-color:#ffffff;font-family:Inter, -apple-system, BlinkMacSystemFont, sans-serif;color:#111111;margin:0;padding:0"><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="max-width:560px;margin:0 auto;padding:32px 24px"><tbody><tr style="width:100%"><td><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="padding-bottom:32px;text-align:center"><tbody><tr><td><img alt="YNOT London" height="36" src="https://staging.ynotlondon.com/brand/ynot-logo-black.png" style="display:inline-block;outline:none;border:none;text-decoration:none;height:auto;max-width:140px" width="140"/></td></tr></tbody></table><h2 style="font-family:Playfair Display, Georgia, serif;font-size:22px">Return instructions for international shipments.</h2><p style="font-size:14px;line-height:24px;margin-top:16px;margin-bottom:16px">Hi Aigerim, your return RT-2026-00010 (from order YN-2026-00050) is approved. We&#x27;ve attached a customs declaration and your original commercial invoice to this email.</p><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="margin-top:24px"><tbody><tr><td><p style="font-size:12px;line-height:24px;text-transform:uppercase;letter-spacing:0.1em;color:#666;margin:0 0 8px;margin-top:0;margin-right:0;margin-bottom:8px;margin-left:0">Items in this return</p><p style="font-size:14px;line-height:24px;margin:4px 0;margin-top:4px;margin-right:0;margin-bottom:4px;margin-left:0">Trench × 1</p></td></tr></tbody></table><hr style="width:100%;border:none;border-top:1px solid #eaeaea;border-color:#e5e5e5;margin:24px 0"/><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation"><tbody><tr><td><p style="font-size:12px;line-height:24px;text-transform:uppercase;letter-spacing:0.1em;color:#666;margin:0 0 8px;margin-top:0;margin-right:0;margin-bottom:8px;margin-left:0">Steps</p><p style="font-size:14px;line-height:24px;margin:4px 0;margin-top:4px;margin-right:0;margin-bottom:4px;margin-left:0">1. Print the attached customs declaration PDF and original commercial invoice.</p><p style="font-size:14px;line-height:24px;margin:4px 0;margin-top:4px;margin-right:0;margin-bottom:4px;margin-left:0">2. Pack the items securely with all original tags.</p><p style="font-size:14px;line-height:24px;margin:4px 0;margin-top:4px;margin-right:0;margin-bottom:4px;margin-left:0">3. Attach both documents to the outside of the parcel in a clear pouch.</p><p style="font-size:14px;line-height:24px;margin:4px 0;margin-top:4px;margin-right:0;margin-bottom:4px;margin-left:0">4. Ship via your local carrier to the address below before 2026-05-20.</p></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="margin-top:24px"><tbody><tr><td><p style="font-size:14px;line-height:24px;margin:0 0 4px;margin-top:0;margin-right:0;margin-bottom:4px;margin-left:0"><strong>Important:</strong> declare as &quot;returned merchandise&quot; on the attached customs form.</p><p style="font-size:14px;line-height:24px;margin:4px 0;margin-top:4px;margin-right:0;margin-bottom:4px;margin-left:0">Mark &quot;YN-2026-00050&quot; clearly on the package exterior so we can match it on arrival.</p></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="margin-top:24px"><tbody><tr><td><p style="font-size:12px;line-height:24px;text-transform:uppercase;letter-spacing:0.1em;color:#666;margin:0 0 8px;margin-top:0;margin-right:0;margin-bottom:8px;margin-left:0">Return address</p><p style="font-size:14px;line-height:24px;margin:0;margin-top:0;margin-bottom:0;margin-left:0;margin-right:0">13 Elvaston Place, Flat 1</p><p style="font-size:14px;line-height:24px;margin:0;margin-top:0;margin-bottom:0;margin-left:0;margin-right:0">London SW7 5QG</p><p style="font-size:14px;line-height:24px;margin:0;margin-top:0;margin-bottom:0;margin-left:0;margin-right:0">United Kingdom</p></td></tr></tbody></table><hr style="width:100%;border:none;border-top:1px solid #eaeaea;border-color:#e5e5e5;margin:48px 0 24px"/><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation"><tbody><tr><td><p style="font-size:12px;line-height:1.5;color:#666666;margin:0;margin-top:0;margin-bottom:0;margin-left:0;margin-right:0">YNOT London · 13 Elvaston Place, Flat 1, London SW7 5QG ·<!-- --> <a href="https://staging.ynotlondon.com" style="color:#666666">staging.ynotlondon.com</a></p></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table><!--/$--></body></html>"`;
